# PostgreSQL connection string. Tables are created by scripts/init.sql.
DATABASE_URL=postgresql://user:password@localhost:5432/inventario

# Secret for session tokens (JWT). Generate with: openssl rand -hex 32
AUTH_SECRET=

# Phone (digits only, with country code) of the member who gets the admin
# view. The admin is a regular member with extra powers; with the demo seed
# this is Alex.
INVENTARIO_ADMIN_PHONE=5511999990001

# Optional: S3 for document storage. Without it, documents up to 8MB are
# stored in the database (base64 fallback).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# Optional: WhatsApp Cloud API for sending first-access codes. Without it,
# the admin generates codes in the Members tab and sends them personally.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE=codigo_acesso
